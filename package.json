{
  "name": "eb3-website",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "sync-public-html": "node scripts/sync-public-html.mjs",
    "dev": "npm run sync-public-html && next dev",
    "build": "npm run sync-public-html && next build",
    "start": "next start",
    "lint": "next lint",
    "preview": "npm run sync-public-html && opennextjs-cloudflare build && opennextjs-cloudflare preview -c wrangler.staging.jsonc",
    "deploy": "npm run sync-public-html && opennextjs-cloudflare build && opennextjs-cloudflare deploy -c wrangler.staging.jsonc"
  },
  "dependencies": {
    "next": "15.5.19",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "1.19.11",
    "@tailwindcss/postcss": "4.3.1",
    "@types/node": "26.0.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "postcss": "8.5.15",
    "tailwindcss": "4.3.1",
    "typescript": "6.0.3",
    "wrangler": "4.103.0"
  }
}
