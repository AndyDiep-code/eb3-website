{
  "output": {
    "filePath": "repomix-output.xml",
    "style": "xml"
  },
  "ignore": {
    "useGitignore": true,
    "useDefaultPatterns": true,
    "customPatterns": [
      "docs/**",
      "plans/**",
      "assets/**",
      "dist/**",
      "coverage/**",
      "build/**",
      "ios/**",
      "android/**",
      "tests/**",
      "__tests__/**",
      "__pycache__/**",
      "node_modules/**",
      ".claude/**",
      ".serena/**",
      ".pnpm-store/**",
      ".github/**",
      ".dart_tool/**",
      ".idea/**",
      ".husky/**",
      ".venv/**",
      ".npmrc",
      "**/repomix-output.*",
      "repomix-*.xml",
      "repomix-*.md",
      "repomix-*.json",
      "repomix-*.txt"
    ]
  }
}
