// ──── EXAMPLE: Auth spec ─────────────────────────────────────

describe('Auth > POST /auth/login', () => {
  it('TC-API-001: Valid credentials return token and user', async () => {
    const res = await request(BASE_URL)
      .post('/auth/login')
      .send({ email: API_CONFIG.credentials.admin.email, password: API_CONFIG.credentials.admin.password });

    expect(res.status).toBe(200);
    expect(res.body).toHaveProperty(API_CONFIG.meta.tokenResponseKey);
    expect(typeof res.body[API_CONFIG.meta.tokenResponseKey]).toBe('string');
    expect(res.body[API_CONFIG.meta.tokenResponseKey].length).toBeGreaterThan(0);
    expect(res.body.user).toMatchObject({ [API_CONFIG.meta.userRoleField]: API_CONFIG.meta.adminRoleValue });
    expect(res.body.user).not.toHaveProperty('password');
  });

  it('TC-API-002: Wrong password returns 401 with generic message', async () => {
    const res = await request(BASE_URL)
      .post('/auth/login')
      .send({ email: API_CONFIG.credentials.admin.email, password: 'WrongPass!' });

    expect(res.status).toBe(401);
  });

  it('TC-API-003: Unknown email returns 401 (same message as wrong password)', async () => {
    const res = await request(BASE_URL)
      .post('/auth/login')
      .send({ email: 'nobody@example.com', password: 'Password123!' });

    expect(res.status).toBe(401);
    // same vague message as wrong password — prevents user enumeration attacks
    expect(res.body).toHaveProperty('message');
  });
});

// ──── EXAMPLE: Resource CRUD spec ────────────────────────────

describe('{{MODULE_NAME}} > POST /{{resource-path}}', () => {
  let adminToken: string;
  let userToken: string;
  let createdId: number;

  beforeAll(async () => {
    adminToken = await getAdminToken();
    userToken = await getUserToken();
  });

  it('TC-RBAC-001: No token returns 401', async () => {
    const res = await request(BASE_URL)
      .post(API_CONFIG.meta.resourceCreatePath)
      .send({ name: 'Test Item' });
    expect(res.status).toBe(401);
  });

  it('TC-RBAC-002: Insufficient role returns 403', async () => {
    const res = await request(BASE_URL)
      .post(API_CONFIG.meta.resourceCreatePath)
      .set(authHeader(userToken))
      .send({ name: 'Test Item' });
    expect(res.status).toBe(403);
  });

  it('TC-API-010: Admin creates resource — returns 201', async () => {
    const res = await request(BASE_URL)
      .post(API_CONFIG.meta.resourceCreatePath)
      .set(authHeader(adminToken))
      .send({ name: 'Test Item', type: 'test' });

    expect(res.status).toBe(201);
    expect(res.body).toHaveProperty('id');
    expect(res.body.name).toBe('Test Item');
    createdId = res.body.id as number;
  });

  it('TC-API-011: Missing required field returns 400', async () => {
    const res = await request(BASE_URL)
      .post(API_CONFIG.meta.resourceCreatePath)
      .set(authHeader(adminToken))
      .send({});
    expect(res.status).toBe(400);
  });
});

// ──── EXAMPLE: Using resolveTestIds for ID-sensitive tests ───

describe('{{MODULE_NAME}} > DELETE /:id', () => {
  let adminToken: string;
  let safeResourceId: number;

  beforeAll(async () => {
    adminToken = await getAdminToken();
    const ids = await resolveTestIds(adminToken);
    safeResourceId = ids.safeResourceId; // freshly created — safe to delete
  });

  it('TC-API-020: Admin deletes own resource — 204', async () => {
    const res = await request(BASE_URL)
      .delete(`${API_CONFIG.meta.resourceCreatePath}/${safeResourceId}`)
      .set(authHeader(adminToken));

    expect(res.status).toBe(204);
  });

  it('TC-API-021: Non-existent id returns 404', async () => {
    const res = await request(BASE_URL)
      .delete(`${API_CONFIG.meta.resourceCreatePath}/9999`)
      .set(authHeader(adminToken));
    expect(res.status).toBe(404);
  });
});

