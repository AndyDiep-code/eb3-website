import { GraphQLClient } from 'graphql-request';

export const GQL_ENDPOINT = '{{GRAPHQL_ENDPOINT}}';

export const GQL_CONFIG = {
  endpoint: GQL_ENDPOINT,
  meta: {
    loginMutation: '{{LOGIN_MUTATION}}',
    tokenPath: '{{TOKEN_PATH}}',          // e.g. "data.login.token"
    meQuery: '{{ME_QUERY}}',              // e.g. "me"
    userRoleField: '{{USER_ROLE_FIELD}}', // e.g. "role"
    adminRoleValue: '{{ADMIN_ROLE_VALUE}}', // e.g. "admin"
    // Path to list all users (used by resolveEntityIds() below)
    // Skill 2 detects this from introspection automatically
    userListQuery: '{{USER_LIST_QUERY}}', // e.g. "users { id role }"
  },
  // Credentials map — supports any number of roles
  // Add entries for each role in your application
  credentials: {
    admin: { query: `{{ADMIN_LOGIN_QUERY}}` },
    user: { query: `{{USER_LOGIN_QUERY}}` },
    // Additional roles auto-populated by Skill 2:
    // alice: { query: `...` },
    // bob: { query: `...` },
  },
} as const;

/** Create a GraphQLClient — pass token for authenticated requests */
export function createClient(token?: string): GraphQLClient {
  return new GraphQLClient(GQL_ENDPOINT, {
    headers: token ? { Authorization: `Bearer ${token}` } : {},
  });
}

/**
 * Extract token from login mutation response using the configured token path.
 * Supports: "data.login.token", "data.auth.token", "data.signin.jwt", etc.
 * graphql-request already unwraps the `data` envelope — adjust path accordingly.
 */
export function extractToken(loginResponse: unknown): string {
  // Strip "data." prefix since graphql-request unwraps the data envelope
  const parts = GQL_CONFIG.meta.tokenPath.replace(/^data\./, '').split('.');
  let val: unknown = loginResponse;
  for (const key of parts) {
    val = (val as Record<string, unknown>)?.[key];
  }
  if (!val || typeof val !== 'string') {
    throw new Error(
      `Token not found at path "${GQL_CONFIG.meta.tokenPath}" in response: ${JSON.stringify(loginResponse)}`
    );
  }
  return val;
}

// ─── Dynamic Entity ID Resolution ────────────────────────────────────────────
// NEVER hardcode entity IDs — they differ between integer and UUID-based projects
// and shift when DB is reseeded. Use resolveEntityIds() in beforeAll() instead.
// ─────────────────────────────────────────────────────────────────────────────

interface EntityIds {
  adminId: string;      // admin user ID (integer or UUID — use as-is)
  userId: string;       // first non-admin user ID
  [key: string]: string; // additional IDs can be added per project
}

let cachedEntityIds: EntityIds | null = null;

/**
 * Resolve actual entity IDs from the live server.
 * Works for both integer IDs (1, 2, 3) and UUID-based projects.
 * Call once in a root beforeAll().
 */
export async function resolveEntityIds(adminToken: string): Promise<EntityIds> {
  if (cachedEntityIds) return cachedEntityIds;

  const client = createClient(adminToken);

  // Query user list using configured query
  const query = `{ ${GQL_CONFIG.meta.userListQuery} }`;
  const response = await client.request<Record<string, Array<{ id: string; [key: string]: unknown }>>>(query);

  // Extract the first key from response.data (the query field name)
  const fieldName = Object.keys(response)[0];
  const users = response[fieldName] as Array<{ id: string; [key: string]: unknown }>;

  if (!users || users.length === 0) {
    throw new Error(`No users found via "${GQL_CONFIG.meta.userListQuery}" — ensure DB is seeded`);
  }

  const adminUser = users.find(u => u[GQL_CONFIG.meta.userRoleField] === GQL_CONFIG.meta.adminRoleValue);
  const regularUser = users.find(u => u[GQL_CONFIG.meta.userRoleField] !== GQL_CONFIG.meta.adminRoleValue);

  cachedEntityIds = {
    adminId: String(adminUser?.id ?? users[0].id),
    userId: String(regularUser?.id ?? users[1]?.id ?? ''),
  };

  return cachedEntityIds;
}

/** Reset ID cache — call if server is reset between test runs */
export function clearEntityIdCache(): void {
  cachedEntityIds = null;
}
