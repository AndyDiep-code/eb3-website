// Generated by playwright-api-supertest
// Static config (base URL + credentials only) — IDs resolved dynamically.
// NEVER hardcode IDs here — they shift when DB is reseeded.

import request from 'supertest';

export const API_CONFIG = {
  baseUrl: '{{BASE_URL}}',
  credentials: {
    admin: { email: '{{ADMIN_EMAIL}}', password: '{{ADMIN_PASSWORD}}' },
    user: { email: '{{USER_EMAIL}}', password: '{{USER_PASSWORD}}' },
  },
  // Meta values derived from api-spec.json at generation time — no hardcoding
  meta: {
    tokenResponseKey: '{{TOKEN_RESPONSE_KEY}}',   // e.g. "access_token"
    userListPath: '{{USER_LIST_PATH}}',            // e.g. "/users"
    userRoleField: '{{USER_ROLE_FIELD}}',          // e.g. "role"
    adminRoleValue: '{{ADMIN_ROLE_VALUE}}',        // e.g. "admin"
    resourceCreatePath: '{{RESOURCE_CREATE_PATH}}', // e.g. "/resources"
    // Full valid body for POST resourceCreatePath — extracted from api-spec.json.operations[POST resourceCreatePath].validExample
    // NEVER use { name: "Temp-xxx" } alone — different APIs require different required fields
    resourceCreateBody: {{RESOURCE_CREATE_BODY}}, // e.g. { name: "Temp", price: 1.0, stock: 1, category: "test" }
  },
} as const;

export const BASE_URL = API_CONFIG.baseUrl;

// ─── Dynamic ID Resolution ────────────────────────────────────────────────────
// Call resolveTestIds() in a root-level beforeAll() once per test run.
// Returns stable IDs derived from the live DB, not hardcoded assumptions.

interface TestIds {
  adminId: string;           // string covers both integer ("1") and UUID ("abc-...")
  userId: string;
  safeResourceId: string;    // freshly created — safe to delete in tests
}

let cachedIds: TestIds | null = null;

export async function resolveTestIds(adminToken: string): Promise<TestIds> {
  if (cachedIds) return cachedIds;

  // Query user list from configured path
  const usersRes = await request(BASE_URL)
    .get(API_CONFIG.meta.userListPath)
    .set({ Authorization: `Bearer ${adminToken}` });

  if (usersRes.status !== 200) {
    throw new Error(`Cannot resolve user IDs: GET ${API_CONFIG.meta.userListPath} returned ${usersRes.status}`);
  }

  const users = usersRes.body as Array<{ id: number; [key: string]: unknown }>;
  const adminUser = users.find(u => u[API_CONFIG.meta.userRoleField] === API_CONFIG.meta.adminRoleValue);
  const regularUser = users.find(u => u[API_CONFIG.meta.userRoleField] !== API_CONFIG.meta.adminRoleValue);

  if (!adminUser || !regularUser) {
    throw new Error('Seed users not found — ensure server is seeded before running tests');
  }

  // Create a fresh deletable resource for cleanup testing
  // Body uses validExample from api-spec.json — covers all required fields for this API
  const createBody = {
    ...API_CONFIG.meta.resourceCreateBody,
    name: `Temp-${Date.now()}`, // unique name to identify test resource
  };
  const resourceRes = await request(BASE_URL)
    .post(API_CONFIG.meta.resourceCreatePath)
    .set({ Authorization: `Bearer ${adminToken}` })
    .send(createBody);

  // Accept 200 or 201 — some frameworks use 200 for creation
  if (resourceRes.status < 200 || resourceRes.status >= 300) {
    throw new Error(`Cannot create test resource at ${API_CONFIG.meta.resourceCreatePath}: HTTP ${resourceRes.status} — body: ${JSON.stringify(resourceRes.body)}`);
  }

  cachedIds = {
    adminId: String(adminUser.id),
    userId: String(regularUser.id),
    safeResourceId: String(resourceRes.body?.id),
  };

  return cachedIds;
}

/** Reset ID cache — call if DB is fully reset between test runs */
export function clearTestIdCache(): void {
  cachedIds = null;
}
