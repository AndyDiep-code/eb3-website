// Generated by playwright-api-supertest
// Provides cached auth tokens for tests — login once per test run

import request from 'supertest';
import { API_CONFIG, BASE_URL } from './api-test-config';

// Token cache — avoids multiple login calls
let adminToken: string | null = null;
let userToken: string | null = null;

async function login(email: string, password: string): Promise<string> {
  const res = await request(BASE_URL)
    .post(API_CONFIG.meta.authLoginPath)  // path from api-spec.json meta, not hardcoded
    .send({ email, password });

  const token = res.body[API_CONFIG.meta.tokenResponseKey];
  if (res.status !== 200 || !token) {
    throw new Error(`Login failed for ${email}: ${res.status} ${JSON.stringify(res.body)}`);
  }
  return token as string;
}

/** Returns cached admin Bearer token. Logs in if not yet cached. */
export async function getAdminToken(): Promise<string> {
  if (!adminToken) {
    adminToken = await login(
      API_CONFIG.credentials.admin.email,
      API_CONFIG.credentials.admin.password,
    );
  }
  return adminToken;
}

/** Returns cached user Bearer token. Logs in if not yet cached. */
export async function getUserToken(): Promise<string> {
  if (!userToken) {
    userToken = await login(
      API_CONFIG.credentials.user.email,
      API_CONFIG.credentials.user.password,
    );
  }
  return userToken;
}

/** Returns Authorization header object for use with supertest .set() */
export function authHeader(token: string): { Authorization: string } {
  return { Authorization: `Bearer ${token}` };
}

/** Clears token cache — call in afterAll if tests modify credentials */
export function clearTokenCache(): void {
  adminToken = null;
  userToken = null;
}
