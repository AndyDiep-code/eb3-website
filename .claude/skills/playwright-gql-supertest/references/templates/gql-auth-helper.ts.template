// Generated by playwright-gql-supertest
// Flexible auth helper — works for any GraphQL project regardless of user count or ID type
import { createClient, GQL_CONFIG, extractToken } from './gql-test-config';

// ─── Token Cache ─────────────────────────────────────────────────────────────
// One cache entry per role key — populated lazily on first use
// Extend this map for additional roles (alice, bob, moderator, etc.)
// ─────────────────────────────────────────────────────────────────────────────

const tokenCache: Record<string, string | null> = {
  admin: null,
  user: null,
};

async function loginWithQuery(query: string): Promise<string> {
  const client = createClient(); // no auth for login mutation
  const response = await client.request(query);
  return extractToken(response);
}

/** Get cached admin token — performs login mutation on first call */
export async function getAdminToken(): Promise<string> {
  if (!tokenCache.admin) {
    tokenCache.admin = await loginWithQuery(GQL_CONFIG.credentials.admin.query);
  }
  return tokenCache.admin;
}

/** Get cached user token — performs login mutation on first call */
export async function getUserToken(): Promise<string> {
  if (!tokenCache.user) {
    tokenCache.user = await loginWithQuery(GQL_CONFIG.credentials.user.query);
  }
  return tokenCache.user;
}

/**
 * Generic token getter for any role configured in GQL_CONFIG.credentials.
 * Use this when you need tokens beyond admin/user (e.g. alice, bob, moderator).
 *
 * @example
 *   const aliceToken = await getTokenForRole('alice');
 *   const bobToken   = await getTokenForRole('bob');
 */
export async function getTokenForRole(role: string): Promise<string> {
  const creds = (GQL_CONFIG.credentials as Record<string, { query: string }>)[role];
  if (!creds) {
    throw new Error(
      `No credentials found for role "${role}". Add it to GQL_CONFIG.credentials in gql-test-config.ts`
    );
  }
  if (!tokenCache[role]) {
    tokenCache[role] = await loginWithQuery(creds.query);
  }
  return tokenCache[role] as string;
}

/** Reset all token caches — call between test suites if needed */
export function clearTokenCache(): void {
  for (const key of Object.keys(tokenCache)) {
    tokenCache[key] = null;
  }
}

// ─── GraphQL Response Assertion Helpers ─────────────────────────────────────
// GraphQL ALWAYS returns HTTP 200.
// Success = `data` exists + `errors` absent
// Failure = `errors` array present (even with HTTP 200)
// ─────────────────────────────────────────────────────────────────────────────

type GqlResponse = { errors?: Array<{ message: string; [key: string]: unknown }> };

/**
 * Assert no GraphQL errors — use for happy path tests.
 * Throws if `errors` array is present in response.
 */
export function assertNoErrors(response: GqlResponse): void {
  if (response.errors && response.errors.length > 0) {
    throw new Error(
      `Expected no GraphQL errors but got:\n${JSON.stringify(response.errors, null, 2)}`
    );
  }
}

/**
 * Assert GraphQL errors are present — use for negative tests.
 * Optionally verify that at least one error message contains the given substring.
 */
export function assertHasError(response: GqlResponse, messageContains?: string): void {
  if (!response.errors || response.errors.length === 0) {
    throw new Error(
      `Expected GraphQL errors but none found. Response:\n${JSON.stringify(response)}`
    );
  }
  if (messageContains) {
    const matched = response.errors.some(e =>
      e.message.toLowerCase().includes(messageContains.toLowerCase())
    );
    if (!matched) {
      throw new Error(
        `Expected error containing "${messageContains}" but got:\n${JSON.stringify(response.errors)}`
      );
    }
  }
}
