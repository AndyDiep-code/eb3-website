// Generated by playwright-gql-supertest — {{OPERATION_GROUP}} tests
import { describe, it, expect, beforeAll } from 'vitest';
import { createClient, GQL_ENDPOINT } from './gql-test-config';
import { getAdminToken, getUserToken, assertNoErrors, assertHasError } from './gql-auth-helper';

// ─── GraphQL testing pattern ──────────────────────────────────────────────────
// GraphQL ALWAYS returns HTTP 200.
// Success: response.data exists AND response.errors is absent/empty.
// Failure: response.errors array contains error objects (even with HTTP 200).
//
// assertNoErrors(response) — for happy path tests
// assertHasError(response, "message") — for auth/validation failure tests
// ─────────────────────────────────────────────────────────────────────────────

describe('{{OPERATION_GROUP}}', () => {
  let adminToken: string;
  let userToken: string;

  beforeAll(async () => {
    adminToken = await getAdminToken();
    userToken = await getUserToken();
  });

  // ── TC-GQL-001: {{OPERATION_NAME}} — Happy path ───────────────────────────
  it('{{OPERATION_NAME}} — returns expected data for authenticated admin', async () => {
    const client = createClient(adminToken);
    const response = await client.request<Record<string, unknown>>(`
      {{HAPPY_PATH_QUERY}}
    `, {{VALID_VARIABLES}});

    assertNoErrors(response as { errors?: Array<{ message: string }> });
    expect((response as Record<string, unknown>).{{RETURN_FIELD}}).toBeDefined();
  });

  // ── TC-GQL-002: {{OPERATION_NAME}} — No auth ──────────────────────────────
  it('{{OPERATION_NAME}} — returns Unauthorized error without token', async () => {
    const client = createClient(); // no token
    try {
      const response = await client.request(`{{HAPPY_PATH_QUERY}}`);
      // Some servers return errors in HTTP 200 response body
      assertHasError(
        response as { errors?: Array<{ message: string }> },
        'Unauthorized'
      );
    } catch (e: unknown) {
      // Some servers throw on HTTP 401 — both patterns are valid GraphQL auth behavior
      const msg = String(e);
      expect(msg).toMatch(/401|Unauthorized|unauthenticated|forbidden/i);
    }
  });

  // ── TC-GQL-003: {{OPERATION_NAME}} — Missing required arg ─────────────────
  it('{{OPERATION_NAME}} — returns validation error for missing required argument', async () => {
    const client = createClient(adminToken);
    // Send query without required variables — GraphQL validates before resolver runs
    const response = await client.request(
      `{{OPERATION_WITHOUT_REQUIRED_VARS}}`,
      {} // empty variables
    ).catch((e: unknown) => e);

    // graphql-request may throw or return errors depending on server config
    if (response instanceof Error) {
      expect(String(response)).toMatch(/variable|required|argument/i);
    } else {
      assertHasError(response as { errors?: Array<{ message: string }> });
    }
  });
});
